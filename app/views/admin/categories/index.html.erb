<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Manage Categories</h1>
    <%= link_to "New Category", new_admin_category_path, class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
  </div>

  <div class="bg-white border rounded-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-6 py-3 text-left">Name</th>
          <th class="px-6 py-3 text-left">Discussions</th>
          <th class="px-6 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-6 py-3"><strong><%= category.name %></strong></td>
            <td class="px-6 py-3"><%= category.discussions.count %></td>
            <td class="px-6 py-3 text-right">
              <%= link_to "Edit", edit_admin_category_path(category), class: "text-blue-600 hover:underline mr-4" %>
              <%= link_to "Delete", admin_category_path(category), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @categories.empty? %>
    <div class="bg-gray-50 border rounded-lg p-8 text-center mt-8">
      <p class="text-gray-600">No categories yet</p>
    </div>
  <% end %>
</div>
