<%= form_with(model: [:admin, category], class: "space-y-4") do |form| %>
  <% if category.errors.any? %>
    <div class="ck-card mb-4" style="border: 1px solid rgba(248,113,113,0.3);">
      <div class="ck-meta mb-2" style="color: #f87171;"><%= pluralize(category.errors.count, "error") %> prevented this from saving</div>
      <ul class="space-y-1">
        <% category.errors.each do |error| %>
          <li class="text-[13px]" style="color: #f87171;"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "ck-meta block mb-1" %>
    <%= form.text_field :name, class: "ck-input" %>
  </div>

  <div>
    <%= form.submit class: "ck-btn-primary", style: "cursor: pointer;" %>
  </div>
<% end %>
