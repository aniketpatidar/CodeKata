<div class="px-12 py-9">
  <div class="mb-8">
    <div class="ck-meta mb-1">Admin · Categories</div>
    <div class="ck-heading">Edit Category</div>
  </div>

  <div class="ck-card" style="max-width: 480px;">
    <%= render "form", category: @category %>
  </div>

  <div class="mt-6 flex gap-4">
    <%= link_to "← Back to Category", admin_category_path(@category), class: "ck-meta", style: "color: #a6d6ff;" %>
    <%= link_to "All Categories", admin_categories_path, class: "ck-meta", style: "color: var(--ck-muted);" %>
  </div>
</div>
