<aside class="w-[240px] h-screen fixed left-0 top-0 overflow-y-auto flex flex-col"
       style="background: var(--ck-bg); border-right: 0.5px solid var(--ck-line);">

  <%# Logo %>
  <div class="px-5 pt-6 pb-4">
    <div class="ck-meta mb-1">Platform</div>
    <div class="text-[#f5f5f7] font-semibold text-[20px] tracking-tight leading-tight">CodeKata</div>
  </div>

  <%# Navigation %>
  <nav class="flex-1 px-3 space-y-0.5">
    <% if user_signed_in? %>

      <% [
        [home_path,        "Home",        "M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 4v4m4-4v4",       -> { current_page?(home_path) }],
        [challenges_path,  "Challenges",  "M13 10V3L4 14h7v7l9-11h-7z",                                                      -> { request.path.start_with?('/challenges') }],
        [(duels_path rescue '#'), "Duels", "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", -> { request.path.start_with?('/duels') }],
        [discussions_path, "Discussions", "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z", -> { request.path.start_with?('/discussions') }],
        [invitations_path, "Friends",     "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", -> { current_page?(invitations_path) }],
      ].each do |path, label, icon_d, active_fn| %>
        <% active = active_fn.call %>
        <a href="<%= path %>"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors <%= active ? 'border-l-2 border-[#a6d6ff] pl-[10px]' : '' %>"
           style="color: <%= active ? '#a6d6ff' : 'var(--ck-muted)' %>; <%= active ? 'background: rgba(166,214,255,0.06);' : '' %>">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= icon_d %>"></path>
          </svg>
          <span><%= label %></span>
        </a>
      <% end %>

      <% if current_user&.admin? %>
        <div class="pt-4 pb-1 px-3">
          <div class="ck-meta text-[9px]">Admin</div>
        </div>

        <% [
          [admin_categories_path, "Categories", "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z", -> { request.path.start_with?('/admin/categories') }],
          [admin_settings_path,   "Settings",   "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z", -> { current_page?(admin_settings_path) }],
        ].each do |path, label, icon_d, active_fn| %>
          <% active = active_fn.call %>
          <a href="<%= path %>"
             class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors <%= active ? 'border-l-2 border-[#a6d6ff] pl-[10px]' : '' %>"
             style="color: <%= active ? '#a6d6ff' : 'var(--ck-muted)' %>; <%= active ? 'background: rgba(166,214,255,0.06);' : '' %>">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= icon_d %>"></path>
            </svg>
            <span><%= label %></span>
          </a>
        <% end %>
      <% end %>

    <% else %>
      <div class="pt-2 pb-1 px-3">
        <div class="ck-meta text-[9px]">Get started</div>
      </div>
      <a href="<%= new_user_session_path %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors" style="color: var(--ck-muted);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
        Sign In
      </a>
      <a href="<%= new_user_registration_path %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors" style="color: var(--ck-muted);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
        Sign Up
      </a>
    <% end %>
  </nav>

  <%# User block (pinned bottom) %>
  <% if user_signed_in? %>
    <div class="px-4 py-3" style="border-top: 0.5px solid var(--ck-line);">
      <div class="flex items-center gap-2 mb-3">
        <%= turbo_stream_from current_user, :notifications %>
        <%= render "nav/notifications", user: current_user %>
      </div>
      <div class="flex items-center gap-3">
        <a href="<%= user_path(current_user) %>" class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold text-[#f5f5f7] shrink-0" style="background: var(--ck-raised);">
          <%= current_user.initials %>
        </a>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-medium text-[#f5f5f7] truncate"><%= current_user.full_name %></div>
          <div class="ck-meta text-[9px]">Member</div>
        </div>
        <a href="<%= destroy_user_session_path %>" data-turbo-method="delete" class="transition-colors" style="color: rgba(248,113,113,0.6);">
          <svg class="w-4 h-4 hover:opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
        </a>
      </div>
    </div>
  <% end %>
</aside>
