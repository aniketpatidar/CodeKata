<%= turbo_frame_tag dom_id(post) do %>
  <div class="ck-card" style="border-radius: 10px; padding: 18px 20px;">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <%= render partial: "discussions/posts/header", locals: { post: post } %>
        <div class="text-[14px] leading-relaxed mt-2" style="color: var(--ck-muted);"><%= post.body %></div>
      </div>
      <% if Current.user&.admin? || Current.user&.id == post.user_id %>
        <div class="flex gap-2 shrink-0">
          <%= link_to edit_discussion_post_path(post.discussion, post),
              data: { turbo_frame: dom_id(post) },
              class: "ck-chip ck-chip--outline" do %>
            Edit
          <% end %>
          <%= button_to "Delete", discussion_post_path(post.discussion, post),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "ck-chip",
              style: "background: rgba(248,113,113,0.15); color: #f87171; cursor: pointer;" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
