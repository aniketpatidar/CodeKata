<div class="px-6 py-8 max-w-2xl mx-auto">
  <div class="mb-8">
    <div class="ck-meta mb-1">Discussions</div>
    <h1 class="ck-heading">Edit Discussion</h1>
  </div>

  <%= turbo_frame_tag dom_id(@discussion) do %>
    <%= render("form", discussion: @discussion) %>
    <div class="mt-4">
      <%= link_to "Cancel", @discussion,
            class: "text-[12px]",
            style: "color: var(--ck-muted); text-decoration: none;" %>
    </div>
  <% end %>
</div>
