<div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white py-8">
  <div class="container mx-auto px-4">
    <h1 class="text-4xl font-bold mb-2">Discussions</h1>
    <p class="text-blue-100">Ask questions and share knowledge with the community</p>
  </div>
</div>

<div class="container mx-auto px-4 py-8">
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Main Content -->
    <div class="lg:flex-1">
      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <%= form_with url: discussions_path, method: :get, local: true do |f| %>
          <div class="flex-1">
            <%= f.text_field :search, placeholder: "Search discussions...", value: params[:search], class: "w-full px-4 py-2 border rounded-lg" %>
          </div>
          <div>
            <%= f.submit "Search", class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
          </div>
          <div>
            <%= link_to "Ask a Question", new_discussion_path, class: "px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700" %>
          </div>
        <% end %>
      </div>

      <div class="space-y-4">
        <% @discussions.each do |discussion| %>
          <div class="bg-white border rounded-lg p-6 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-3">
              <div class="flex-1">
                <h3 class="text-xl font-semibold mb-2">
                  <%= link_to discussion.title, discussion_path(discussion), class: "text-blue-600 hover:underline" %>
                </h3>
                <p class="text-gray-600"><%= truncate(discussion.description, length: 150) %></p>
              </div>
              <div class="ml-4 text-right">
                <p class="text-2xl font-bold text-blue-600"><%= discussion.posts.count %></p>
                <p class="text-xs text-gray-500">replies</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-2 mb-4">
              <% discussion.categories.each do |category| %>
                <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded">
                  <%= category.name %>
                </span>
              <% end %>
            </div>

            <div class="flex items-center justify-between text-sm text-gray-500">
              <div>
                Asked by <%= discussion.user.full_name %>
              </div>
              <div>
                <%= time_ago_in_words(discussion.created_at) %> ago
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @discussions.empty? %>
        <div class="bg-gray-50 border rounded-lg p-12 text-center">
          <p class="text-gray-600 mb-4">No discussions found</p>
          <%= link_to "Ask the first question!", new_discussion_path, class: "text-blue-600 hover:underline" %>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="lg:w-64 space-y-6">
      <!-- Hot Questions -->
      <div class="bg-white border rounded-lg p-6">
        <h3 class="font-bold text-lg mb-4">Hot Discussions</h3>
        <div class="space-y-3">
          <% @hot_discussions ||= Discussion.order('posts_count DESC').limit(5) %>
          <% @hot_discussions.each do |d| %>
            <div>
              <p class="text-sm font-semibold">
                <%= link_to truncate(d.title, length: 40), discussion_path(d), class: "text-blue-600 hover:underline" %>
              </p>
              <p class="text-xs text-gray-500"><%= d.posts.count %> replies</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Categories -->
      <div class="bg-white border rounded-lg p-6">
        <h3 class="font-bold text-lg mb-4">Categories</h3>
        <div class="space-y-2">
          <% Category.all.limit(10).each do |category| %>
            <p>
              <%= link_to category.name, discussions_path(category_id: category.id), class: "text-blue-600 hover:underline text-sm" %>
              <span class="text-gray-500 text-xs">(<%= category.discussions.count %>)</span>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
