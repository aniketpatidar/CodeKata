<%= form_with(model: discussion, class: "space-y-6") do |form| %>
  <% if discussion.errors.any? %>
    <div class="ck-card" style="border-left: 2px solid #f87171;">
      <p class="ck-meta mb-2" style="color: #f87171;"><%= pluralize(discussion.errors.count, "error") %> prevented this from saving</p>
      <ul class="space-y-0.5">
        <% discussion.errors.each do |error| %>
          <li class="text-[13px]" style="color: var(--ck-ink);"><%= error.options[:message] %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "ck-meta block mb-1" do %>
      Title
      <span class="normal-case ml-2" style="font-family: inherit; font-size: 11px; color: var(--ck-muted);">Be specific and imagine you're asking another person.</span>
    <% end %>
    <%= form.text_field :name, class: "ck-input" %>
  </div>

  <div>
    <%= form.label :description, class: "ck-meta block mb-1" do %>
      Details
      <span class="normal-case ml-2" style="font-family: inherit; font-size: 11px; color: var(--ck-muted);">Expand on what you put in the title. Minimum 20 characters.</span>
    <% end %>
    <%= form.rich_text_area :description, class: "ck-input min-h-[120px]" %>
  </div>

  <div>
    <%= form.label :categories, class: "ck-meta block mb-1" do %>
      Tags
      <span class="normal-case ml-2" style="font-family: inherit; font-size: 11px; color: var(--ck-muted);">Add up to 5 tags.</span>
    <% end %>
    <%= form.collection_select :category_ids, Category.order(:name), :id, :name, {},
          { class: "ck-input", multiple: true, "data-controller": "select2" } %>
  </div>

  <div class="flex items-center gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= form.check_box :pinned, class: "rounded" %>
      <span class="text-[13px]" style="color: var(--ck-muted);">Pinned</span>
    </label>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= form.check_box :closed, class: "rounded" %>
      <span class="text-[13px]" style="color: var(--ck-muted);">Closed</span>
    </label>
  </div>

  <%= form.submit "Post Your Question", class: "ck-btn-primary", style: "cursor: pointer;" %>
<% end %>
