<div class="min-h-screen">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">Friend Invitations</h1>

    <div class="max-w-4xl">
    <!-- Tabs -->
    <div class="flex gap-4 mb-8 border-b">
      <button class="px-4 py-2 border-b-2 border-blue-600 text-blue-600 font-semibold transition" id="received-tab">
        Received Invitations (<%= current_user.received_invitations.count %>)
      </button>
      <button class="px-4 py-2 text-gray-600 font-semibold hover:text-gray-800 transition" id="sent-tab">
        Sent Invitations (<%= current_user.sent_invitations.count %>)
      </button>
      <button class="px-4 py-2 text-gray-600 font-semibold hover:text-gray-800 transition" id="friends-tab">
        Your Friends (<%= current_user.friends.count %>)
      </button>
      <button class="px-4 py-2 text-gray-600 font-semibold hover:text-gray-800 transition" id="find-tab">
        Find People
      </button>
    </div>

    <!-- Received Invitations -->
    <div id="received-content">
      <% if current_user.received_invitations.any? %>
        <div class="space-y-4">
          <% current_user.received_invitations.each do |invitation| %>
            <div class="bg-white border rounded-lg p-4 flex items-center justify-between hover:shadow-md transition">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white font-bold">
                  <%= invitation.user.initials %>
                </div>
                <div>
                  <p class="font-semibold"><%= link_to invitation.user.full_name, user_path(invitation.user), class: "text-blue-600 hover:underline" %></p>
                  <p class="text-sm text-gray-500">
                    Invited <%= time_ago_in_words(invitation.created_at) %> ago
                  </p>
                </div>
              </div>
              <div class="flex gap-2">
                <%= button_to "Accept", accept_invitation_path(invitation), method: :post,
                    class: "px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition text-sm font-medium" %>
                <%= button_to "Decline", decline_invitation_path(invitation), method: :post,
                    class: "px-4 py-2 border border-gray-300 text-gray-600 rounded hover:bg-gray-50 transition text-sm font-medium" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-8 text-center">
          <p class="text-gray-600 mb-4">No pending invitations</p>
          <button class="text-blue-600 hover:underline font-medium" id="go-to-find">Search for friends</button>
        </div>
      <% end %>
    </div>

    <!-- Sent Invitations -->
    <div id="sent-content" class="hidden">
      <% if current_user.sent_invitations.any? %>
        <div class="space-y-4">
          <% current_user.sent_invitations.each do |invitation| %>
            <div class="bg-white border rounded-lg p-4 flex items-center justify-between hover:shadow-md transition">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white font-bold">
                  <%= invitation.friend.initials %>
                </div>
                <div>
                  <p class="font-semibold"><%= link_to invitation.friend.full_name, user_path(invitation.friend), class: "text-blue-600 hover:underline" %></p>
                  <p class="text-sm text-gray-500">
                    Invited <%= time_ago_in_words(invitation.created_at) %> ago
                  </p>
                </div>
              </div>
              <div>
                <%= button_to "Cancel", decline_invitation_path(invitation), method: :post,
                    class: "px-4 py-2 border border-gray-300 text-gray-600 rounded hover:bg-gray-50 transition text-sm font-medium" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-purple-50 border border-purple-200 rounded-lg p-8 text-center">
          <p class="text-gray-600">No sent invitations</p>
        </div>
      <% end %>
    </div>

    <!-- Friends -->
    <div id="friends-content" class="hidden">
      <% if current_user.friends.any? %>
        <div class="space-y-4">
          <% current_user.friends.each do |friend| %>
            <div class="bg-white border rounded-lg p-4 flex items-center justify-between hover:shadow-md transition">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center text-white font-bold">
                  <%= friend.initials %>
                </div>
                <div>
                  <p class="font-semibold"><%= link_to friend.full_name, user_path(friend), class: "text-blue-600 hover:underline" %></p>
                  <p class="text-sm text-gray-500">Friend since <%= time_ago_in_words(Invitation.where("(user_id = ? AND friend_id = ?) OR (user_id = ? AND friend_id = ?)", current_user.id, friend.id, friend.id, current_user.id).where(confirmed: true).first.created_at) %> ago</p>
                </div>
              </div>
              <div>
                <%= link_to "View Profile", user_path(friend),
                    class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition text-sm font-medium" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-8 text-center">
          <p class="text-gray-600 mb-4">No friends yet</p>
          <button class="text-green-600 hover:underline font-medium" id="go-to-find-2">Find people to connect with</button>
        </div>
      <% end %>
    </div>

    <!-- Find People -->
    <div id="find-content" class="hidden">
      <% available_users = @users.reject { |u| u == current_user || current_user.friend_with?(u) || Invitation.reacted?(current_user.id, u.id) } %>
      <% if available_users.any? %>
        <div class="space-y-4">
          <% available_users.each do |user| %>
            <div class="bg-white border rounded-lg p-4 flex items-center justify-between hover:shadow-md transition">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-yellow-400 to-orange-600 flex items-center justify-center text-white font-bold">
                  <%= user.initials %>
                </div>
                <div>
                  <p class="font-semibold"><%= link_to user.full_name, user_path(user), class: "text-blue-600 hover:underline" %></p>
                  <p class="text-sm text-gray-500">@<%= user.slug %></p>
                </div>
              </div>
              <div>
                <%= button_to "Send Invitation", invitations_path, params: { user_id: user.id }, method: :post,
                    class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition text-sm font-medium" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8 text-center">
          <p class="text-gray-600">No users available to connect with at the moment</p>
        </div>
      <% end %>
    </div>
    </div>
  </div>
</div>

<script>
  const tabs = [
    { button: 'received-tab', content: 'received-content' },
    { button: 'sent-tab', content: 'sent-content' },
    { button: 'friends-tab', content: 'friends-content' },
    { button: 'find-tab', content: 'find-content' }
  ];

  function activateTab(tabIndex) {
    tabs.forEach(tab => {
      const button = document.getElementById(tab.button);
      const content = document.getElementById(tab.content);
      button.classList.remove('border-b-2', 'border-blue-600', 'text-blue-600');
      button.classList.add('text-gray-600', 'hover:text-gray-800');
      content.classList.add('hidden');
    });

    const activeTab = tabs[tabIndex];
    document.getElementById(activeTab.button).classList.add('border-b-2', 'border-blue-600', 'text-blue-600');
    document.getElementById(activeTab.button).classList.remove('text-gray-600', 'hover:text-gray-800');
    document.getElementById(activeTab.content).classList.remove('hidden');
  }

  tabs.forEach((tab, index) => {
    document.getElementById(tab.button).addEventListener('click', () => activateTab(index));
  });

  // Quick nav to find tab
  const goToFind = document.getElementById('go-to-find');
  const goToFind2 = document.getElementById('go-to-find-2');
  if (goToFind) goToFind.addEventListener('click', () => activateTab(3));
  if (goToFind2) goToFind2.addEventListener('click', () => activateTab(3));
</script>
