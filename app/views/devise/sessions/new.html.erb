<div class="flex items-center justify-center min-h-screen px-4">
  <div class="w-full max-w-md">
    <div class="ck-meta mb-1 text-center">Welcome back</div>
    <div class="ck-heading text-center mb-8">Sign In</div>

    <div class="ck-card" style="border-radius: 16px; padding: 32px;">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "ck-meta block mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "ck-input" %>
          </div>

          <div>
            <%= f.label :password, class: "ck-meta block mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "ck-input" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me, class: "ck-meta cursor-pointer" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "ck-btn-primary w-full mt-2", style: "cursor: pointer;" %>
        </div>
      <% end %>

      <div class="mt-6 space-y-2 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
