<div class="flex items-center justify-center min-h-screen px-4 py-12">
  <div class="w-full max-w-md">
    <div class="ck-meta mb-1 text-center">Join CodeKata</div>
    <div class="ck-heading text-center mb-8">Create Account</div>

    <div class="ck-card" style="border-radius: 16px; padding: 32px;">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :first_name, class: "ck-meta block mb-1" %>
            <%= f.text_field :first_name, autofocus: true, class: "ck-input" %>
          </div>

          <div>
            <%= f.label :last_name, class: "ck-meta block mb-1" %>
            <%= f.text_field :last_name, class: "ck-input" %>
          </div>

          <div>
            <%= f.label :email, class: "ck-meta block mb-1" %>
            <%= f.email_field :email, autocomplete: "email", class: "ck-input" %>
          </div>

          <div>
            <%= f.label :avatar, class: "ck-meta block mb-1" %>
            <%= f.select :avatar,
                [["Cooool Cactus", "cool-cactus.png"], ["DOGE", "cool-doge.png"], ["Funky Duck", "cool-duck.png"], ["Coolest duck", "coolest-duck.jpg"]],
                { include_blank: false },
                class: "ck-input" %>
          </div>

          <div>
            <%= f.label :password, class: "ck-meta block mb-1" %>
            <% if @minimum_password_length %>
              <span class="ck-meta text-[9px] ml-2">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "ck-input" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "ck-meta block mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "ck-input" %>
          </div>

          <%= f.submit "Create account", class: "ck-btn-primary w-full mt-2", style: "cursor: pointer;" %>
        </div>
      <% end %>

      <div class="mt-6 space-y-2 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
