<div class="flex items-center justify-center min-h-screen px-4">
  <div class="w-full max-w-md">
    <div class="ck-meta mb-1 text-center">Account recovery</div>
    <div class="ck-heading text-center mb-8">Reset Password</div>

    <div class="ck-card" style="border-radius: 16px; padding: 32px;">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "ck-meta block mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "ck-input" %>
          </div>

          <%= f.submit "Send reset instructions", class: "ck-btn-primary w-full mt-2", style: "cursor: pointer;" %>
        </div>
      <% end %>

      <div class="mt-6 space-y-2 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
