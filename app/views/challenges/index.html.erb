<div class="px-12 py-9">
  <%# Page header + search %>
  <div class="flex items-end justify-between mb-8">
    <div>
      <div class="ck-meta mb-1">Challenges</div>
      <div class="ck-heading">All Problems</div>
    </div>
    <%= form_tag challenges_path, method: :get,
        data: { turbo_frame: "search-results", turbo_action: "advance", controller: "search", action: "input->search#submit" } do %>
      <div class="flex gap-2">
        <%= text_field_tag "query", params[:query],
            placeholder: "Search...",
            class: "ck-input",
            style: "width: 260px;" %>
        <%= submit_tag "Search", class: "ck-btn-outline", style: "cursor: pointer;" %>
      </div>
    <% end %>
  </div>

  <%# Challenge list %>
  <div id="challenges-list">
    <%= turbo_frame_tag "search-results" do %>
      <div class="space-y-2">
        <% @challenges.each do |challenge| %>
          <a href="/challenges/<%= challenge.name %>"
             data-turbo-frame="_top"
             class="flex items-center justify-between px-5 py-4 rounded-[10px] transition-colors"
             style="background: var(--ck-card);"
             onmouseover="this.style.background='var(--ck-raised)'"
             onmouseout="this.style.background='var(--ck-card)'">
            <div class="flex items-center gap-4">
              <span class="ck-meta w-8 text-right shrink-0"><%= challenge.id %></span>
              <div>
                <div class="text-[14px] font-medium"><%= challenge.name %></div>
                <div class="text-[12px] mt-0.5" style="color: var(--ck-muted);"><%= challenge.description.truncate(60) %></div>
              </div>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <% if challenge.respond_to?(:language) && challenge.language.present? %>
                <span class="ck-chip ck-chip--outline"><%= challenge.language %></span>
              <% end %>
              <span class="ck-chip ck-chip--<%= challenge.difficulty.downcase %>"><%= challenge.difficulty %></span>
              <% if user_signed_in? && ChallengeCompletion.exists?(user: current_user, challenge: challenge) %>
                <svg class="w-4 h-4" fill="none" stroke="#a6d6ff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Pagination %>
  <div class="mt-6">
    <%== pagy_nav(@pagy) %>
  </div>
</div>
