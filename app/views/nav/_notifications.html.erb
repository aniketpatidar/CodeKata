<a href="<%= notifications_path %>" class="relative p-1 rounded-lg transition-colors"
   style="color: var(--ck-muted); display: inline-flex; align-items: center;"
   onmouseover="this.style.color='var(--ck-ink)'" onmouseout="this.style.color='var(--ck-muted)'">
  <span class="sr-only">Notifications</span>
  <%= inline_svg_tag('bell.svg', class: "h-4 w-4") %>
  <% if user.notifications.unread.exists? %>
    <div class="absolute -top-0.5 -right-0.5">
      <div class="inline-flex items-center justify-center w-3.5 h-3.5 rounded-full text-[9px] font-semibold" style="background: #f87171; color: #0e0e10;">
        <%= user.notifications.unread.count %>
      </div>
    </div>
  <% end %>
</a>
