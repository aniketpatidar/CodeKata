<div class="px-6 py-8 max-w-4xl mx-auto">
  <div class="flex items-start justify-between mb-8">
    <div>
      <div class="ck-meta mb-1">Explore</div>
      <h1 class="ck-heading">Categories</h1>
    </div>
    <% if current_user&.admin? %>
      <%= link_to "New Category", admin_categories_path, class: "ck-btn-primary" %>
    <% end %>
  </div>

  <% if @categories.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @categories.each do |category| %>
        <%= link_to category_path(category),
              class: "ck-card group flex flex-col gap-2 transition-colors",
              style: "text-decoration: none;" do %>
          <p class="text-[14px] font-medium" style="color: var(--ck-ink); transition: color 0.15s;"
             onmouseover="this.style.color='var(--ck-accent)'" onmouseout="this.style.color='var(--ck-ink)'">
            <%= category.name %>
          </p>
          <p class="ck-meta"><%= category.discussions.count %> discussions</p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="ck-card text-center py-16">
      <p class="text-[14px]" style="color: var(--ck-muted);">No categories yet</p>
    </div>
  <% end %>
</div>
