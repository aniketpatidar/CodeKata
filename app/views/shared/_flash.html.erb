<div class="fixed bottom-6 right-6 z-50 pointer-events-none">
  <div data-controller="alert"
       class="max-w-sm w-full pointer-events-auto rounded-xl px-4 py-3 flex items-start gap-3"
       style="background: var(--ck-card); border: 0.5px solid var(--ck-faint); box-shadow: 0 8px 32px rgba(0,0,0,0.4);">
    <div class="flex-1 min-w-0">
      <div class="ck-meta mb-0.5 <%= level.to_s == 'alert' ? '' : '' %>"
           style="color: <%= level.to_s == 'alert' ? '#f87171' : '#a6d6ff' %>;">
        <%= level.to_s == 'alert' ? 'Error' : 'Notice' %>
      </div>
      <p class="text-[13px]" style="color: var(--ck-ink);"><%= content %></p>
    </div>
    <button data-action="alert#close"
            class="shrink-0 mt-0.5 transition-colors"
            style="color: var(--ck-muted); background: none; border: none; cursor: pointer;">
      <%= inline_svg_tag 'close.svg', class: 'h-4 w-4' %>
    </button>
  </div>
</div>
