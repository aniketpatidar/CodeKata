# Judge0 API key from RapidAPI (https://rapidapi.com/judge0-official/api/judge0-ce)
JUDGE0_API_KEY=your_rapidapi_key_here

# Gemini API key from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (defaults to localhost if not set)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional — falls back to config/database.yml)
# DATABASE_URL=postgresql://user:password@localhost/codekata_development
